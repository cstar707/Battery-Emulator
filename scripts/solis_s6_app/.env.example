# Optional: copy to .env and override. .env is gitignored.
# Defaults match solar-monitoring: broker 10.10.53.92, user api, password test12345.
# TODO: After cutover, remove default creds from code and require MQTT_USER/MQTT_PASSWORD in .env only.

# MQTT_HOST=10.10.53.92
# MQTT_PORT=1883
# MQTT_USER=api
# MQTT_PASSWORD=test12345
# MQTT_TOPIC_PREFIX: default "solis" publishes to solis/sensors/<key>.
# For Waveshare display (subscribes to solar/solis/sensors/#), use:
# MQTT_TOPIC_PREFIX=solar/solis

# Solark board HTTP auth (if the board's web UI requires login). Used for GET /solark_data.
# SOLARK_HTTP_USER=your_board_web_username
# SOLARK_HTTP_PASSWORD=your_board_web_password
# SOLARK1_HTTP_PORT=80
# Solark data is also read from MQTT topic solar/solark (same broker as above). Set SOLARK_MQTT_TOPIC to override.
# SOLARK_MQTT_TOPIC=solar/solark

# If daily PV (Energy today) shows wrong value (e.g. 26 instead of 15.2 from inverter display),
# set scale to correct it. E.g. SOLIS_DAILY_PV_SCALE=0.585 when inverter shows 15.2 but app shows 26.
# GET /api/debug/register/33035 shows raw register value for debugging.
# SOLIS_DAILY_PV_SCALE=1.0

# Total PV energy (33029-33030): S6 uses 0.01 kWh so divisor 100. If total showed ~10x too high (e.g. 156 instead of 15.6), keep 100.
# GET /api/debug/register/33029-33030 shows raw and computed. Set SOLIS_TOTAL_PV_DIVISOR=10 if total is 10x too small.
# SOLIS_TOTAL_PV_DIVISOR=100

# Tabuchi today PV (kWh): static value for grid-status total. Change from 15 to 3 in Settings or here.
# TABUCHI_TODAY_PV_KWH=3

# Battery capacity (kWh) per inverter. Editable in Settings.
# SOLIS1_BATTERY_KWH=48
# SOLIS2_BATTERY_KWH=48
# SOLARK1_BATTERY_KWH=64

# Home Assistant (10.10.53.179) — used for curtailment switch control via SmartLife/Tuya
# HA_URL=http://10.10.53.179:8123
# HA_TOKEN=<long-lived token from HA profile page>
# HA_SWITCH_IQ8=switch.enphase_iq8_micro_socket_1        # Envoy 2 (10.10.53.186)
# HA_SWITCH_MSERIES=switch.shed_micro_inverters_socket_1  # Envoy 1 (10.10.53.194)
# HA_SWITCH_TABUCHI=switch.sonoff_1001204d65_1            # Tabuchi export

# AI / LLM controls (disabled by default so legacy automation remains the fallback)
# SOLAR_LLM_AUTOMATIONS_ENABLED=false
# SOLAR_LLM_HOST=10.10.53.164
# SOLAR_LLM_PORT=11434
# SOLAR_LLM_API_STYLE=ollama
# SOLAR_LLM_MODEL=llama3.1:8b
# SOLAR_LLM_TIMEOUT_SEC=45
